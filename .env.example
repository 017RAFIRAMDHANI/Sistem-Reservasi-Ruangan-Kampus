APP_DEBUG=false
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&options=endpoint%3DENDPOINT_ID

# Contoh endpoint ID diambil dari bagian awal host Neon.
# Host: ep-nama-project-xxxxx-pooler.region.aws.neon.tech
# Endpoint ID: ep-nama-project-xxxxx-pooler

